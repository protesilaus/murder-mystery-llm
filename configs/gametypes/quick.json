{
  "name": "quick",
  "version": "1.0",
  "description": "Faster game with more AP, immediate investigation results, and no round 1 restrictions",
  "player_settings": {
    "min_players": 4,
    "max_players": 8,
    "actions_per_player": 5
  },
  "phases": [
    {
      "name": "night",
      "turn_order": "role_priority",
      "role_priority": ["detective", "murderer"],
      "end_condition": "all_acted",
      "ap_reset": false
    },
    {
      "name": "day",
      "turn_order": "sequential",
      "role_priority": [],
      "end_condition": "ap_exhausted_or_all_passed",
      "ap_reset": true
    },
    {
      "name": "vote",
      "turn_order": "sequential",
      "role_priority": [],
      "end_condition": "votes_cast",
      "ap_reset": false
    }
  ],
  "roles": {
    "murderer": {
      "team": "mafia",
      "count": 1,
      "abilities": [
        {
          "action": "kill",
          "phase": "night",
          "uses_per_round": 1,
          "reveal_delay": 0
        }
      ]
    },
    "detective": {
      "team": "town",
      "count": 1,
      "abilities": [
        {
          "action": "investigate",
          "phase": "night",
          "uses_per_round": 1,
          "reveal_delay": 0
        }
      ]
    },
    "town": {
      "team": "town",
      "count": "remaining",
      "abilities": []
    }
  },
  "actions": {
    "speak": {
      "ap_cost": 1,
      "ap_threshold": 1,
      "phases": ["day"]
    },
    "question": {
      "ap_cost": 1,
      "ap_threshold": 1,
      "phases": ["day"]
    },
    "poll": {
      "ap_cost": 1,
      "ap_threshold": 1,
      "phases": ["day"]
    },
    "vote": {
      "ap_cost": 0,
      "ap_threshold": 0,
      "phases": ["vote"]
    },
    "kill": {
      "ap_cost": 0,
      "ap_threshold": 0,
      "phases": ["night"]
    },
    "investigate": {
      "ap_cost": 0,
      "ap_threshold": 0,
      "phases": ["night"]
    },
    "whisper_send": {
      "ap_cost": 1,
      "ap_threshold": 1,
      "phases": ["day"]
    },
    "whisper_reply": {
      "ap_cost": 1,
      "ap_threshold": 1,
      "phases": ["day"]
    },
    "pass": {
      "ap_cost": 0,
      "ap_threshold": 0,
      "phases": ["night", "day", "vote"]
    }
  },
  "win_conditions": [
    {
      "winner": "town",
      "condition_type": "role_eliminated",
      "role": "murderer"
    },
    {
      "winner": "murderer",
      "condition_type": "custom_count",
      "team": "town",
      "count_lte": 1
    }
  ],
  "special_rules": {
    "round_1_skip_kill": false,
    "opening_body_event": false,
    "investigation_reveal_delay": 0
  }
}
